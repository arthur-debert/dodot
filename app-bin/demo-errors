#!/usr/bin/env bash
# Spin up a synthetic dotfiles sandbox that exercises every error/warning
# path in dodot, then run a sequence of commands against it so you can
# eyeball the rendered output.
#
# Conditions set up in the sandbox (not 1:1 with the numbered command
# runs below — those are a separate sequence):
#   - Healthy pack                     → deploys clean
#   - Pending with conflict            → row stays pending, note attached
#   - Stale deployment                 → user link removed after up
#   - Cross-pack target collision      → surfaces via the trailing conflicts section
#   - Failing install.sh               → row flips to error + note
#   - Ignored pack                     → listed under Ignored Packs
#   - Adopt on a non-dotted file       → surfaces an error from the CLI
#
# Usage:
#   app-bin/demo-errors              # run the demo, clean up at the end
#   app-bin/demo-errors --keep       # leave the sandbox on disk and print its path
#   app-bin/demo-errors --release    # use target/release/dodot (must be built first)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

keep=false
profile="debug"
for arg in "$@"; do
	case "$arg" in
	--keep) keep=true ;;
	--release) profile="release" ;;
	-h | --help)
		sed -n '2,23p' "$0"
		exit 0
		;;
	*)
		echo "unknown arg: $arg" >&2
		exit 2
		;;
	esac
done

DODOT="$PROJECT_ROOT/target/$profile/dodot"
if [[ ! -x "$DODOT" ]]; then
	echo "building dodot ($profile)..."
	if [[ "$profile" == "release" ]]; then
		(cd "$PROJECT_ROOT" && cargo build --release --quiet)
	else
		(cd "$PROJECT_ROOT" && cargo build --quiet)
	fi
fi

sandbox="$(mktemp -d -t dodot-demo.XXXXXX)"
if ! $keep; then
	trap 'rm -rf "$sandbox"' EXIT
fi

export HOME="$sandbox/home"
export DOTFILES_ROOT="$sandbox/dotfiles"
export XDG_DATA_HOME="$sandbox/data"
export XDG_CONFIG_HOME="$sandbox/config"
unset XDG_STATE_HOME XDG_CACHE_HOME || true
mkdir -p "$HOME" "$DOTFILES_ROOT" "$XDG_DATA_HOME" "$XDG_CONFIG_HOME"

banner() {
	printf '\n\033[1;34m━━━ %s ━━━\033[0m\n' "$*"
}

run() {
	printf '\n\033[1;33m$ dodot %s\033[0m\n' "$*"
	"$DODOT" "$@" || true
}

# ─── 1. Healthy pack ─────────────────────────────────────────────
mkdir -p "$DOTFILES_ROOT/git"
cat >"$DOTFILES_ROOT/git/home.gitconfig" <<'EOF'
[user]
  name = Demo User
  email = demo@example.com
EOF

# ─── 2. Pending-conflict: user has existing ~/.vimrc ─────────────
mkdir -p "$DOTFILES_ROOT/vim"
echo 'set nocompatible' >"$DOTFILES_ROOT/vim/home.vimrc"
echo 'my hand-edited vimrc' >"$HOME/.vimrc"

# ─── 3. Stale (user link will be removed after up) ──────────────
mkdir -p "$DOTFILES_ROOT/zsh"
echo 'alias ll="ls -la"' >"$DOTFILES_ROOT/zsh/home.zshrc"

# ─── 5. Cross-pack target collision (two packs claim ~/.bashrc) ──
mkdir -p "$DOTFILES_ROOT/bash-work" "$DOTFILES_ROOT/bash-home"
echo '# work bashrc' >"$DOTFILES_ROOT/bash-work/home.bashrc"
echo '# home bashrc' >"$DOTFILES_ROOT/bash-home/home.bashrc"

# ─── 6. Failing install.sh ───────────────────────────────────────
mkdir -p "$DOTFILES_ROOT/badinstall"
cat >"$DOTFILES_ROOT/badinstall/install.sh" <<'EOF'
#!/usr/bin/env bash
echo "pretending to install something..."
echo "boom: dependency missing" >&2
exit 1
EOF
chmod +x "$DOTFILES_ROOT/badinstall/install.sh"

# ─── 7. Ignored pack ─────────────────────────────────────────────
mkdir -p "$DOTFILES_ROOT/archived"
touch "$DOTFILES_ROOT/archived/.dodotignore"
echo 'stale = true' >"$DOTFILES_ROOT/archived/home.oldrc"

banner "Sandbox layout"
(cd "$sandbox" && find . -maxdepth 4 -not -path '*/\.*' -o -name '.dodotignore' | sort)

banner "1. dodot status  — before anything is deployed"
# Expected: vim pending [N], bash-* pending, badinstall never run, cross-pack
# conflict section at the bottom, Ignored Packs section listing 'archived'.
run status

banner "2. dodot up      — cross-pack conflict blocks everything"
# Expected: hard failure with the conflicts rendered cleanly. Nothing deployed.
run up

# Resolve the cross-pack collision by removing one of the duplicates so the
# rest of the demo can proceed.
rm -rf "$DOTFILES_ROOT/bash-home"

banner "3. dodot up      — with the cross-pack conflict resolved"
# Expected:
#   - git, zsh, bash-work → deployed
#   - vim                 → error [N] (conflict: ~/.vimrc exists)
#   - badinstall          → error [N] (install script exit 1)
run up

# Engineer a stale deployment by removing zsh's user link.
rm -f "$HOME/.zshrc"

banner "4. dodot status  — post-up with a stale deployment introduced"
# Expected:
#   - git       → deployed
#   - zsh       → stale (user link missing, re-deploy to fix)
#   - vim       → pending [N] with note (still blocked by ~/.vimrc)
#   - bash-work → deployed
#   - badinstall→ never run (install still hasn't succeeded)
run status

banner "5. dodot adopt non-dotted-file  — surfaces an error from the CLI"
echo 'irrelevant' >"$HOME/notdotted"
# Expected: adopt fails with a message explaining the non-dotted round-trip rule.
# (This path surfaces via the standard CLI error channel, not the notes list,
# because adopt bails before it ever reaches the status rendering layer.)
run adopt git "$HOME/notdotted"

banner "Done."
if $keep; then
	printf '\nSandbox kept at:\n  %s\n' "$sandbox"
	printf 'Re-run dodot against it with:\n  HOME=%s DOTFILES_ROOT=%s XDG_DATA_HOME=%s XDG_CONFIG_HOME=%s %s <cmd>\n' \
		"$HOME" "$DOTFILES_ROOT" "$XDG_DATA_HOME" "$XDG_CONFIG_HOME" "$DODOT"
fi
