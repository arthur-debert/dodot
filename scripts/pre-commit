#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook for dodot.
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

cd "$(git rev-parse --show-toplevel)" || exit 1

# Auto-format staged Rust files and re-stage them
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
if [ -n "$STAGED_RS" ]; then
    cargo fmt --all
    for f in $STAGED_RS; do
        [ -f "$f" ] && git add "$f"
    done
fi

# Run the same checks CI uses
exec scripts/check
