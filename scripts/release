#!/usr/bin/env bash
# Thin shim around the canonical release-cut CLI (arthur-debert/release/bin/release-cut).
# This repo's workspace-only root Cargo.toml doesn't carry the version — it
# lives in `crates/dodot-lib/Cargo.toml`. RELEASE_CUT_MANIFEST points at it.
export RELEASE_CUT_MANIFEST=crates/dodot-lib/Cargo.toml
exec release-cut "$@"
